---
import BaseLayout from '../layouts/BaseLayout.astro';
import { STORIA_MILESTONES, SITE, NOTABLE_ATHLETES } from '../data/site.js';
---

<BaseLayout
  title="Storia — Sci Club Orezzo"
  description="La storia dello Sci Club Orezzo dal 1968 ad oggi. Fondato da Tarcisio Merelli a Orezzo, Gazzaniga. Oltre mezzo secolo di sci alpino nella Valle Seriana."
>

  <!-- Hero -->
  <section class="relative py-32 md:py-40 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="/img/neve-sfondo.jpg" alt="" class="w-full h-full object-cover opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/70 via-brand-dark/50 to-brand-blue/20"></div>
    </div>
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F0F4F8"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-blue text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Dal 1968</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        La Nostra Storia
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        Oltre mezzo secolo di passione per lo sci. Dalla pizzeria di Tarcisio ai circuiti nazionali.
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-3xl mx-auto">
      <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal">
        Lo Sci Club Orezzo nasce nel <strong>1968</strong> per iniziativa di <strong>Tarcisio Merelli</strong>
        e un gruppo di amici appassionati di sci. La prima sede e il luogo di lavoro di Tarcisio:
        la pizzeria di famiglia, "<strong>La Penzana del Merel</strong>", nella piccola frazione di Orezzo,
        nel comune di Gazzaniga, cuore della Valle Seriana bergamasca.
      </p>
      <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal reveal-delay-1">
        Negli anni il club si affilia al <strong>CSI</strong> e alla <strong>FISI</strong>, entrando nei circuiti federali.
        L'attivita cresce: dai viaggi turistici in autobus verso le piste si passa rapidamente allo sci agonistico.
        Il figlio di Tarcisio, <strong>Efrem Merelli</strong>, diventa campione italiano di slalom gigante nel 1983
        e vince la Coppa Italia nel 1985, dimostrando che da Orezzo si puo arrivare ai vertici nazionali.
      </p>
      <p class="text-lg text-brand-dark/80 leading-relaxed mb-6 reveal reveal-delay-2">
        In oltre mezzo secolo il club ha avviato allo sci <strong>piu di mille atleti</strong>, producendo oltre
        25 sciatori competitivi a livello nazionale. Tra questi, <strong>Michela Azzola</strong> di Albino e
        <strong>Marta Benzoni</strong> di Rovetta hanno raggiunto il livello nazionale.
      </p>
      <p class="text-lg text-brand-dark/80 leading-relaxed reveal reveal-delay-3">
        Oggi lo Sci Club Orezzo conta <strong>57 atleti agonisti</strong> e <strong>118 tesserati</strong>,
        gareggia nelle tre discipline <strong>sci alpino, sci di fondo e sci alpinismo</strong>,
        e organizza il "<strong>Trofeo La Penzana del Merel</strong>" a Lizzola per il circuito provinciale FISI Bergamo.
        Amicizia, serenita e divertimento vanno di pari passo con competizione, disciplina e rigore:
        e questa la filosofia che Tarcisio ha trasmesso dal primo giorno.
      </p>
    </div>
  </section>

  <!-- Group photo -->
  <section class="px-5 pb-16">
    <div class="max-w-4xl mx-auto reveal">
      <div class="border-2 border-brand-dark shadow-[6px_6px_0_#1A1A1A] overflow-hidden">
        <img src="/img/gruppo.jpg" alt="Il gruppo dello Sci Club Orezzo" class="w-full h-auto" loading="lazy" />
      </div>
      <p class="text-center text-xs text-brand-dark/40 mt-3 font-medium">Il gruppo dello Sci Club Orezzo</p>
    </div>
  </section>

  <!-- Timeline milestones -->
  <section class="py-16 md:py-24 px-5 bg-brand-dark text-white" id="tappe">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-center mb-16 reveal">Le Tappe Fondamentali</h2>

      <div class="relative">
        <div class="absolute left-8 md:left-1/2 top-0 bottom-0 w-px bg-white/10" aria-hidden="true"></div>

        {STORIA_MILESTONES.map((m, i) => {
          const isLeft = i % 2 === 0;
          return (
            <div class={`relative mb-12 md:mb-16 md:flex ${isLeft ? 'md:flex-row' : 'md:flex-row-reverse'} reveal reveal-delay-${Math.min(i % 4 + 1, 4)}`}>
              <div class="absolute left-8 md:left-1/2 -translate-x-1/2 top-2 z-10">
                <div class="w-4 h-4 rounded-full bg-brand-blue border-2 border-brand-blue"></div>
              </div>
              <div class={`ml-16 md:ml-0 md:w-[calc(50%-2rem)] ${isLeft ? 'md:pr-0 md:mr-auto' : 'md:pl-0 md:ml-auto'}`}>
                <div class="bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition-colors">
                  <span class="font-display text-3xl font-bold text-brand-blue">{m.year}</span>
                  <h3 class="font-display text-lg font-bold text-white mt-2 mb-2">{m.title}</h3>
                  <p class="text-white/60 text-sm leading-relaxed">{m.text}</p>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Notable athletes -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-brand-dark text-center mb-12 reveal">Atleti di Rilievo</h2>
      <div class="space-y-4">
        {NOTABLE_ATHLETES.map((a, i) => (
          <div class={`flex items-center gap-4 bg-white border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] p-5 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="text-brand-blue font-display font-bold text-sm bg-brand-blue/10 px-3 py-1 flex-shrink-0">{a.era}</span>
            <div>
              <span class="font-display font-bold text-brand-dark">{a.name}</span>
              <span class="text-brand-dark/50 text-sm block">{a.achievement}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Key numbers -->
  <section class="py-16 md:py-24 px-5 bg-brand-snow">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-brand-dark text-center mb-12 reveal">I Numeri</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { num: '1968', label: 'Anno di fondazione' },
          { num: '1000+', label: 'Atleti formati' },
          { num: '25+', label: 'Atleti nazionali' },
          { num: '57', label: 'Agonisti attuali' },
        ].map((stat, i) => (
          <div class={`text-center bg-white border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] p-6 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="font-display text-3xl md:text-4xl font-bold text-brand-blue block">{stat.num}</span>
            <span class="text-xs text-brand-dark/50 font-bold tracking-wider uppercase mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-5">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-dark/60 text-sm mb-4">Vuoi far parte della nostra storia?</p>
      <a href="/contatti/" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-dark text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-blue hover:border-brand-blue transition-all">
        Contattaci
      </a>
    </div>
  </section>

  <div class="text-center py-12">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-brand-blue hover:underline">
      &larr; Torna alla home
    </a>
  </div>

</BaseLayout>
