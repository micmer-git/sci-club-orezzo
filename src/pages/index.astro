---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, BOARD, SPONSORS, DISCIPLINES, VENUES, FEATURED_EVENT, GALLERY_IMAGES, NOTABLE_ATHLETES, RESULTS } from '../data/site.js';
const recentPodiums = RESULTS.filter(r => r.podium && r.position > 0).slice(0, 6);
---

<BaseLayout
  title="Sci Club Orezzo — Sci Alpino dal 1968"
  description="ASD Sci Club Orezzo Valseriana, societa di sci alpino fondata nel 1968 a Orezzo, Gazzaniga, Valle Seriana. 57 atleti agonisti, vivaio giovanile, gare FISI."
>

  <!-- ========== HERO ========== -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-brand-dark" id="hero">
    <!-- Real mountain background -->
    <div class="absolute inset-0">
      <img src="/img/montagna-sfondo.jpg" alt="" class="w-full h-full object-cover opacity-30" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/60 via-brand-dark/40 to-brand-blue/30"></div>
    </div>
    <!-- Mountain silhouette -->
    <div class="absolute bottom-0 left-0 right-0 z-10">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F0F4F8"/>
      </svg>
    </div>

    <div class="relative z-20 text-center px-5 max-w-4xl mx-auto">
      <!-- Club logo -->
      <div class="mb-8 reveal">
        <img src="/img/logo-sci-club-orezzo.jpg" alt="Logo Sci Club Orezzo" class="w-24 h-auto mx-auto rounded-lg shadow-2xl border-2 border-white/20" />
      </div>
      <p class="text-brand-blue text-xs font-bold tracking-[0.25em] uppercase mb-6 reveal reveal-delay-1">Orezzo, Valle Seriana — dal 1968</p>
      <h1 class="font-cursive text-white text-[clamp(3.5rem,12vw,9rem)] leading-[0.85] mb-4 reveal reveal-delay-2" style="text-shadow: 0 4px 30px rgba(0,0,0,0.4);">
        Sci Club Orezzo
      </h1>
      <p class="font-display text-brand-blue text-[clamp(0.9rem,2.5vw,1.6rem)] tracking-[0.3em] uppercase font-bold mb-3 reveal reveal-delay-3">
        Sci Alpino &bull; Fondo &bull; Alpinismo
      </p>
      <p class="text-white/50 text-sm mb-10 reveal reveal-delay-3">
        {SITE.athleteCount} atleti agonisti &bull; {SITE.memberCount} tesserati &bull; FISI Bergamo
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-4">
        <a href="#attivita" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-blue text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-blue hover:bg-transparent hover:text-brand-blue transition-all">
          Le nostre attivita
        </a>
        <a href="#societa" class="inline-flex items-center gap-2 px-7 py-3 bg-transparent text-white font-bold text-sm tracking-wider uppercase border-2 border-white/40 hover:border-white hover:bg-white/10 transition-all">
          Chi siamo
        </a>
      </div>
    </div>
  </section>

  <!-- ========== INSTAGRAM CAROUSEL ========== -->
  <section class="py-12 md:py-16 px-5 bg-brand-snow" id="instagram">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <svg class="w-6 h-6 text-brand-dark" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          <h2 class="font-display text-xl md:text-2xl font-bold text-brand-dark">@scicluborezzo</h2>
          <span class="hidden sm:inline text-xs text-brand-dark/40 font-medium">275 post &bull; 1.059 follower</span>
        </div>
        <a href="https://www.instagram.com/scicluborezzo/" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-5 py-2 bg-brand-dark text-white text-xs font-bold tracking-wider uppercase hover:bg-brand-blue transition-colors">
          Seguici
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>

      <div class="ig-slider-container overflow-hidden relative">
        <div class="ig-slider flex gap-4 transition-transform duration-500 ease-out" id="igSlider">
          {GALLERY_IMAGES.map((img, i) => (
            <div class="ig-card flex-shrink-0 w-[260px] md:w-[300px] group">
              <a href="https://www.instagram.com/scicluborezzo/" target="_blank" rel="noopener noreferrer" class="block no-underline">
                <div class="aspect-square overflow-hidden border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] group-hover:shadow-[2px_2px_0_#1A1A1A] group-hover:translate-x-[2px] group-hover:translate-y-[2px] transition-all">
                  <img src={img.src} alt={img.alt} class="w-full h-full object-cover" loading={i < 3 ? 'eager' : 'lazy'} />
                </div>
                <p class="mt-3 text-xs text-brand-dark/60 font-medium">{img.caption}</p>
              </a>
            </div>
          ))}
          <!-- CTA card -->
          <div class="ig-card flex-shrink-0 w-[260px] md:w-[300px] group">
            <a href="https://www.instagram.com/scicluborezzo/" target="_blank" rel="noopener noreferrer" class="block no-underline">
              <div class="aspect-square overflow-hidden border-2 border-brand-blue bg-gradient-to-br from-brand-blue/20 to-brand-blue/5 flex items-center justify-center">
                <div class="text-center px-8">
                  <svg class="w-12 h-12 text-brand-blue mx-auto mb-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                  <p class="font-display text-lg font-bold text-brand-dark mb-2">Vedi tutti i post</p>
                  <p class="text-xs text-brand-dark/50">Segui @scicluborezzo su Instagram</p>
                </div>
              </div>
            </a>
          </div>
        </div>
        <button class="ig-prev absolute left-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-brand-dark text-white flex items-center justify-center hover:bg-brand-blue transition-colors opacity-0 pointer-events-none" aria-label="Precedente">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <button class="ig-next absolute right-0 top-1/2 -translate-y-1/2 z-10 w-10 h-10 bg-brand-dark text-white flex items-center justify-center hover:bg-brand-blue transition-colors" aria-label="Successivo">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- ========== MARQUEE ========== -->
  <div class="bg-brand-blue h-14 overflow-hidden flex items-center">
    <div class="marquee-track">
      {[...Array(8)].map(() => (
        <span class="flex-shrink-0 text-white font-display text-lg font-bold tracking-wider pr-8">
          SCI ALPINO &bull; SLALOM &bull; GIGANTE &bull; SUPER G &bull; FONDO &bull; ALPINISMO &bull; DAL 1968 &bull;
        </span>
      ))}
    </div>
  </div>

  <!-- ========== FEATURED EVENT ========== -->
  <section class="py-20 md:py-28 px-5" id="evento">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Il nostro evento</p>
          <h2 class="font-display text-[clamp(2rem,5vw,3.5rem)] font-bold text-brand-dark leading-tight mb-6 reveal reveal-delay-1">
            {FEATURED_EVENT.name}
          </h2>
          <p class="text-brand-dark/70 text-lg leading-relaxed mb-8 reveal reveal-delay-2">
            {FEATURED_EVENT.description}
          </p>
          <div class="flex flex-wrap gap-4 mb-8 reveal reveal-delay-3">
            <div class="bg-white px-5 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A]">
              <span class="block text-[0.65rem] font-bold tracking-[0.15em] uppercase text-brand-blue">Sede</span>
              <span class="font-display text-lg font-bold">{FEATURED_EVENT.location}</span>
            </div>
            <div class="bg-white px-5 py-3 border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A]">
              <span class="block text-[0.65rem] font-bold tracking-[0.15em] uppercase text-brand-blue">Categorie</span>
              <span class="font-display text-lg font-bold">{FEATURED_EVENT.categories}</span>
            </div>
          </div>
        </div>
        <div class="relative reveal reveal-delay-2">
          <div class="border-2 border-brand-dark shadow-[6px_6px_0_#1A1A1A] aspect-[4/3] overflow-hidden">
            <img src="/img/gara-lizzola.jpg" alt="Gara di sci a Lizzola — sede del Trofeo La Penzana del Merel" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-3 -right-3 bg-brand-dark text-white px-5 py-2 font-display text-sm font-bold tracking-wider">
            Lizzola — Valbondione
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== DISCIPLINES ========== -->
  <section class="py-20 md:py-28 px-5 bg-brand-snow" id="attivita">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Cosa facciamo</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          Le Nostre Discipline
        </h2>
        <p class="text-brand-dark/60 max-w-xl mx-auto reveal reveal-delay-2">
          Tre discipline, una passione. Dal 1968 formiamo sciatori sulle montagne delle Orobie bergamasche.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {DISCIPLINES.map((d, i) => (
          <div class={`bg-white border-2 border-brand-dark shadow-[5px_5px_0_#1A1A1A] hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-[2px_2px_0_#1A1A1A] transition-all p-8 text-center reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="text-5xl block mb-4">{d.icon}</span>
            <h3 class="font-display text-xl font-bold text-brand-dark mb-3">{d.name}</h3>
            <p class="text-sm text-brand-dark/60 leading-relaxed">{d.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== RECENT RESULTS ========== -->
  <section class="py-20 md:py-28 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Ultimi podi</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          Risultati Recenti
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 max-w-4xl mx-auto">
        {recentPodiums.map((r, i) => (
          <div class={`bg-white border-2 border-brand-blue/20 shadow-[4px_4px_0_#0066B3] p-5 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="flex items-center gap-3 mb-3">
              <span class="w-10 h-10 flex items-center justify-center bg-brand-blue text-white font-display font-bold text-lg">{r.position}°</span>
              <div>
                <span class="font-bold text-brand-dark text-sm block">{r.athlete}</span>
                <span class="text-brand-blue text-[0.65rem] font-bold tracking-wider uppercase">{r.category}</span>
              </div>
            </div>
            <p class="text-xs text-brand-dark/50 truncate">{r.race}</p>
            {r.note && <p class="text-xs text-brand-blue mt-1 font-medium">{r.note}</p>}
          </div>
        ))}
      </div>

      <div class="text-center mt-10 reveal reveal-delay-4">
        <a href="/risultati/" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-dark text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-blue hover:border-brand-blue transition-all">
          Tutti i risultati &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ========== VENUES ========== -->
  <section class="py-20 md:py-28 px-5 bg-brand-dark text-white" id="gare">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Dove gareggiamo</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-4 reveal reveal-delay-1">
          Le Nostre Piste
        </h2>
        <p class="text-white/60 max-w-xl mx-auto reveal reveal-delay-2">
          Dalle Orobie al Tonale, le localita dove allenarsi e competere con i colori dello Sci Club Orezzo.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {VENUES.map((v, i) => (
          <div class={`bg-white/5 border border-white/10 p-6 hover:bg-white/10 transition-colors reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="w-12 h-12 bg-brand-blue/20 rounded-full flex items-center justify-center mb-4">
              <span class="text-2xl">🏔️</span>
            </div>
            <h3 class="font-display text-xl font-bold text-white mb-1">{v.name}</h3>
            <p class="text-brand-blue text-xs font-bold tracking-wider uppercase mb-3">{v.location}</p>
            <p class="text-white/60 text-sm leading-relaxed">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== SOCIETA / BOARD ========== -->
  <section class="py-20 md:py-28 px-5" id="societa">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">La Societa</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          Chi Siamo
        </h2>
        <p class="text-brand-dark/60 max-w-xl mx-auto reveal reveal-delay-2">
          Fondato nel 1968 da Tarcisio Merelli nella storica pizzeria "La Penzana del Merel" a Orezzo.
          Amicizia, serenita e divertimento vanno di pari passo con competizione, disciplina e rigore.
        </p>
      </div>

      <!-- Key numbers -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-3xl mx-auto mb-16">
        {[
          { num: '1968', label: 'Anno di fondazione' },
          { num: '57', label: 'Atleti agonisti' },
          { num: '118', label: 'Tesserati' },
          { num: '1000+', label: 'Atleti formati' },
        ].map((stat, i) => (
          <div class={`text-center bg-white border-2 border-brand-dark shadow-[4px_4px_0_#1A1A1A] p-6 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="font-display text-3xl md:text-4xl font-bold text-brand-blue block">{stat.num}</span>
            <span class="text-xs text-brand-dark/50 font-bold tracking-wider uppercase mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>

      <!-- Board -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-2xl mx-auto mb-16">
        {BOARD.map((member, i) => (
          <div class={`bg-brand-snow border-2 border-brand-dark/10 p-6 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <div class="flex items-center gap-4 mb-3">
              <div class="w-14 h-14 bg-brand-blue/20 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="font-display text-brand-blue font-bold text-lg">{member.name.charAt(0)}</span>
              </div>
              <div>
                <h3 class="font-bold text-brand-dark">{member.name}</h3>
                <p class="text-brand-blue text-[0.7rem] font-bold tracking-wider uppercase">{member.role}</p>
              </div>
            </div>
            {member.note && <p class="text-sm text-brand-dark/60 leading-relaxed">{member.note}</p>}
          </div>
        ))}
      </div>

      <!-- Notable athletes -->
      <div class="max-w-2xl mx-auto">
        <h3 class="font-display text-xl font-bold text-brand-dark text-center mb-6 reveal">Atleti di Rilievo</h3>
        <div class="space-y-3">
          {NOTABLE_ATHLETES.map((a, i) => (
            <div class={`flex items-center gap-4 bg-white border border-brand-dark/10 p-4 reveal reveal-delay-${Math.min(i + 1, 4)}`}>
              <span class="text-brand-blue font-display font-bold text-sm bg-brand-blue/10 px-3 py-1 flex-shrink-0">{a.era}</span>
              <div>
                <span class="font-bold text-brand-dark text-sm">{a.name}</span>
                <span class="text-brand-dark/50 text-xs block">{a.achievement}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ========== SPONSORS ========== -->
  <section class="py-16 md:py-20 px-5 bg-brand-snow" id="sponsor">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Insieme</p>
        <h2 class="font-display text-[clamp(1.5rem,4vw,2.5rem)] font-bold text-brand-dark leading-tight reveal reveal-delay-1">
          Sponsor e Partner
        </h2>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {SPONSORS.map((sponsor, i) => (
          <a
            href={sponsor.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`bg-white border-2 px-5 py-6 text-center no-underline hover:scale-[1.03] transition-all reveal reveal-delay-${Math.min(i + 1, 4)} ${sponsor.tier === 'main' ? 'border-brand-blue/40 shadow-[3px_3px_0_#0066B3]' : sponsor.tier === 'technical' ? 'border-amber-500/30 shadow-[3px_3px_0_#d97706]' : 'border-brand-dark/10 shadow-[2px_2px_0_#1A1A1A20]'}`}
          >
            <span class={`block text-[0.6rem] font-bold tracking-[0.15em] uppercase mb-2 ${sponsor.tier === 'main' ? 'text-brand-blue' : sponsor.tier === 'technical' ? 'text-amber-600' : 'text-brand-dark/40'}`}>
              {sponsor.tier === 'main' ? 'Main Sponsor' : sponsor.tier === 'technical' ? 'Partner Tecnico' : 'Supporter'}
            </span>
            <span class="font-display text-sm font-bold text-brand-dark block">{sponsor.name}</span>
            {sponsor.desc && <span class="block text-[0.55rem] text-brand-dark/30 mt-1">{sponsor.desc}</span>}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ========== CTA ========== -->
  <section class="py-20 md:py-28 px-5 bg-brand-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/img/neve-sfondo.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-6 reveal">
        Vuoi entrare nel club?
      </h2>
      <p class="text-white/60 text-lg mb-10 reveal reveal-delay-1">
        Iscrizioni aperte per tutte le categorie, dai Baby ai Master.
        Contattaci per informazioni sui corsi e l'attivita agonistica.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-2">
