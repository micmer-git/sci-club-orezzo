  <!-- Cursor snow trail + Sliders JS -->
  <script>
    (() => {
      // === Subtle cursor snow (hero section only) ===
      const heroSection = document.getElementById('hero');
      if (heroSection && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        let lastTime = 0;
        heroSection.addEventListener('mousemove', (e) => {
          const now = Date.now();
          if (now - lastTime < 80) return;
          lastTime = now;
          const particle = document.createElement('div');
          particle.className = 'cursor-particle';
          particle.style.left = e.clientX + 'px';
          particle.style.top = e.clientY + 'px';
          document.body.appendChild(particle);
          setTimeout(() => particle.remove(), 1000);
        });
      }

      // === Instagram slider ===
      const slider = document.getElementById('igSlider');
      const prev = document.querySelector('.ig-prev');
      const next = document.querySelector('.ig-next');
      if (slider && prev && next) {
        let pos = 0;
        const cardW = slider.querySelector('.ig-card')?.offsetWidth || 300;
        const gap = 16;
        const step = cardW + gap;

        function getMaxScroll() {
          return Math.max(0, slider.scrollWidth - slider.parentElement.offsetWidth);
        }

        function update() {
          const maxScroll = getMaxScroll();
          slider.style.transform = `translateX(-${pos}px)`;
          prev.classList.toggle('opacity-0', pos <= 0);
          prev.classList.toggle('pointer-events-none', pos <= 0);
          next.classList.toggle('opacity-0', pos >= maxScroll);
          next.classList.toggle('pointer-events-none', pos >= maxScroll);
        }

        next.addEventListener('click', () => { pos = Math.min(pos + step, getMaxScroll()); update(); });
        prev.addEventListener('click', () => { pos = Math.max(pos - step, 0); update(); });

        let startX = 0, startPos = 0;
        slider.addEventListener('touchstart', (e) => { startX = e.touches[0].clientX; startPos = pos; }, { passive: true });
        slider.addEventListener('touchmove', (e) => {
          const dx = startX - e.touches[0].clientX;
          pos = Math.max(0, Math.min(startPos + dx, getMaxScroll()));
          slider.style.transition = 'none';
          slider.style.transform = `translateX(-${pos}px)`;
        }, { passive: true });
        slider.addEventListener('touchend', () => {
          slider.style.transition = '';
          pos = Math.round(pos / step) * step;
          pos = Math.max(0, Math.min(pos, getMaxScroll()));
          update();
        });

        update();
      }

      // === Sponsor carousel ===
      const sponsorSlider = document.getElementById('sponsorSlider');
      const sponsorPrev = document.querySelector('.sponsor-prev');
      const sponsorNext = document.querySelector('.sponsor-next');
      if (sponsorSlider && sponsorPrev && sponsorNext) {
        let sPos = 0;
        const sCardW = sponsorSlider.querySelector('.sponsor-card')?.offsetWidth || 320;
        const sGap = 20;
        const sStep = sCardW + sGap;

        function sGetMaxScroll() {
          return Math.max(0, sponsorSlider.scrollWidth - sponsorSlider.parentElement.offsetWidth);
        }

        function sUpdate() {
          const maxScroll = sGetMaxScroll();
          sponsorSlider.style.transform = `translateX(-${sPos}px)`;
          sponsorPrev.classList.toggle('opacity-0', sPos <= 0);
          sponsorPrev.classList.toggle('pointer-events-none', sPos <= 0);
          sponsorNext.classList.toggle('opacity-0', sPos >= maxScroll);
          sponsorNext.classList.toggle('pointer-events-none', sPos >= maxScroll);
        }

        sponsorNext.addEventListener('click', () => { sPos = Math.min(sPos + sStep, sGetMaxScroll()); sUpdate(); });
        sponsorPrev.addEventListener('click', () => { sPos = Math.max(sPos - sStep, 0); sUpdate(); });

        // Touch/swipe
        let sStartX = 0, sStartPos = 0;
        sponsorSlider.addEventListener('touchstart', (e) => { sStartX = e.touches[0].clientX; sStartPos = sPos; }, { passive: true });
        sponsorSlider.addEventListener('touchmove', (e) => {
          const dx = sStartX - e.touches[0].clientX;
          sPos = Math.max(0, Math.min(sStartPos + dx, sGetMaxScroll()));
          sponsorSlider.style.transition = 'none';
          sponsorSlider.style.transform = `translateX(-${sPos}px)`;
        }, { passive: true });
        sponsorSlider.addEventListener('touchend', () => {
          sponsorSlider.style.transition = '';
          sPos = Math.round(sPos / sStep) * sStep;
          sPos = Math.max(0, Math.min(sPos, sGetMaxScroll()));
          sUpdate();
        });

        // Auto-scroll every 4 seconds
        let autoInterval = setInterval(() => {
          const maxScroll = sGetMaxScroll();
          if (sPos >= maxScroll) {
            sPos = 0;
          } else {
            sPos = Math.min(sPos + sStep, maxScroll);
          }
          sUpdate();
        }, 4000);

        // Pause auto-scroll on hover
        sponsorSlider.parentElement.addEventListener('mouseenter', () => clearInterval(autoInterval));
        sponsorSlider.parentElement.addEventListener('mouseleave', () => {
          autoInterval = setInterval(() => {
            const maxScroll = sGetMaxScroll();
            if (sPos >= maxScroll) {
              sPos = 0;
            } else {
              sPos = Math.min(sPos + sStep, maxScroll);
            }
            sUpdate();
          }, 4000);
        });

        sUpdate();
      }
    })();
  </script>

</BaseLayout>
