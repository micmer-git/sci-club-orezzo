---
import BaseLayout from '../layouts/BaseLayout.astro';
import { RESULTS, NOTABLE_ATHLETES, COACHING_STAFF, LEGENDS, SITE } from '../data/site.js';

// Separate competitive results from organizational entries
const competitive = RESULTS.filter(r => r.pos > 0);
const organizational = RESULTS.filter(r => r.pos === 0);

// Group competitive results by decade
const decades = [
  { label: '2020s', range: [2020, 2029], desc: 'Nuova generazione, pettorali rossi e il rilancio post-COVID' },
  { label: '2010s', range: [2010, 2019], desc: 'Dominio provinciale e il Trofeo San Simone' },
  { label: '2000s', range: [2000, 2009], desc: 'Atleti nazionali e mille sciatori formati' },
  { label: '1980s', range: [1980, 1989], desc: 'La generazione d\'oro — Efrem Merelli campione italiano' },
];

function getDecade(dateStr) {
  const y = parseInt(dateStr.substring(0, 4));
  return decades.find(d => y >= d.range[0] && y <= d.range[1]);
}

function fmtDate(dateStr) {
  const [y, m, d] = dateStr.split('-');
  const months = ['Gen','Feb','Mar','Apr','Mag','Giu','Lug','Ago','Set','Ott','Nov','Dic'];
  return `${parseInt(d)} ${months[parseInt(m)-1]} ${y}`;
}

const resultsByDecade = {};
competitive.forEach(r => {
  const dec = getDecade(r.date);
  if (!dec) return;
  if (!resultsByDecade[dec.label]) resultsByDecade[dec.label] = [];
  resultsByDecade[dec.label].push(r);
});
// Sort each decade's results by date descending
Object.values(resultsByDecade).forEach(arr => arr.sort((a, b) => b.date.localeCompare(a.date)));
---

<BaseLayout
  title="Risultati — Sci Club Orezzo"
  description="20 anni di risultati dello Sci Club Orezzo Valseriana. Gare FISI, circuito provinciale, campionati regionali e nazionali di sci alpino."
>

  <!-- Hero -->
  <section class="relative py-28 md:py-36 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="/img/gara-gigante.jpeg" alt="" class="w-full h-full object-cover opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/80 via-brand-dark/60 to-brand-blue/20"></div>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-blue text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Dal 1983 a oggi</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,4.5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        Risultati e Palmares
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        Oltre vent'anni di gare, podi e pettorali rossi nei circuiti FISI provinciali, regionali e nazionali.
      </p>
    </div>
  </section>

  <!-- Notable athletes — compact pills -->
  <section class="py-12 md:py-16 px-5">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-display text-2xl font-bold text-brand-dark mb-6 text-center reveal">Atleti di Rilievo</h2>
      <div class="flex flex-wrap justify-center gap-2">
        {NOTABLE_ATHLETES.map((a, i) => (
          <div class={`inline-flex items-center gap-2 bg-white border border-brand-dark/10 px-3 py-2 hover:border-brand-blue/30 transition-colors reveal reveal-delay-${Math.min(i % 4 + 1, 4)}`}>
            <span class="text-brand-blue font-display font-bold text-[0.6rem] bg-brand-blue/10 px-1.5 py-0.5">{a.era}</span>
            <span class="font-bold text-brand-dark text-xs">{a.name}</span>
            <span class="text-brand-dark/40 text-[0.65rem] hidden sm:inline">{a.achievement}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Results table by decade -->
  <section class="py-16 md:py-24 px-5 bg-brand-dark text-white">
    <div class="max-w-6xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-center mb-16 reveal">Archivio Risultati</h2>

      {decades.map((dec, di) => {
        const rows = resultsByDecade[dec.label];
        if (!rows || rows.length === 0) return null;
        const podiumCount = rows.filter(r => r.podium).length;
        return (
          <div class={`mb-16 last:mb-0 reveal reveal-delay-${Math.min(di % 4 + 1, 4)}`}>
            {/* Decade header */}
            <div class="flex items-center gap-4 mb-2">
              <span class="font-display text-4xl md:text-5xl font-bold text-brand-blue">{dec.label}</span>
              <div class="flex-1 h-px bg-white/10"></div>
              <span class="text-xs font-bold text-white/40 tracking-wider uppercase">
                {rows.length} risultat{rows.length === 1 ? 'o' : 'i'} / {podiumCount} pod{podiumCount === 1 ? 'io' : 'i'}
              </span>
            </div>
            <p class="text-white/40 text-sm mb-6 italic">{dec.desc}</p>

            {/* Table */}
            <div class="overflow-x-auto">
              <table class="w-full text-sm border-collapse">
                <thead>
                  <tr class="text-left text-[0.65rem] font-bold text-brand-blue tracking-wider uppercase border-b border-white/10">
                    <th class="py-2 pr-3">Data</th>
                    <th class="py-2 pr-3">Atleta</th>
                    <th class="py-2 pr-3 hidden sm:table-cell">Gara</th>
                    <th class="py-2 pr-3 text-center w-12">Pos</th>
                    <th class="py-2 pr-3 hidden md:table-cell">Categoria</th>
                    <th class="py-2">Note</th>
                  </tr>
                </thead>
                <tbody>
                  {rows.map((r, ri) => (
                    <tr class={`border-b border-white/5 ${ri % 2 === 0 ? 'bg-white/[0.02]' : 'bg-white/[0.05]'} ${r.podium ? 'bg-brand-blue/10' : ''} hover:bg-brand-blue/5 transition-colors`}>
                      <td class="py-2 pr-3 text-white/50 text-xs whitespace-nowrap">{fmtDate(r.date)}</td>
                      <td class="py-2 pr-3 font-medium text-white">{r.athlete}</td>
                      <td class="py-2 pr-3 text-white/40 hidden sm:table-cell truncate max-w-[200px]">{r.race}</td>
                      <td class="py-2 pr-3 text-center">
                        <span class={`inline-flex items-center justify-center w-7 h-7 text-xs font-bold ${r.pos <= 3 && r.podium ? 'bg-brand-blue text-white' : 'bg-white/10 text-white/60'}`}>
                          {r.pos}&deg;
                        </span>
                      </td>
                      <td class="py-2 pr-3 text-[0.65rem] text-brand-blue font-bold tracking-wider uppercase hidden md:table-cell">{r.cat}</td>
                      <td class="py-2 text-xs text-brand-blue">{r.note || ''}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        );
      })}

      {/* Organizational entries — separate notes */}
      {organizational.length > 0 && (
        <div class="mt-16 reveal">
          <div class="flex items-center gap-4 mb-6">
            <span class="font-display text-xl font-bold text-white/60">Note Organizzative</span>
            <div class="flex-1 h-px bg-white/10"></div>
          </div>
          <div class="space-y-2">
            {organizational.map(r => (
              <div class="flex items-center gap-3 px-4 py-2 bg-white/[0.03] border border-white/5 text-sm">
                <span class="text-white/40 text-xs whitespace-nowrap">{fmtDate(r.date)}</span>
                <span class="text-white/60">{r.race}</span>
                <span class="text-brand-blue text-xs ml-auto">{r.note || ''}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Coaching Staff -->
  <section class="py-12 md:py-16 px-5 bg-brand-ice">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-2xl font-bold text-brand-dark text-center mb-8 reveal">Staff Tecnico</h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {COACHING_STAFF.map((s, i) => (
          <div class={`bg-white border border-brand-dark/10 p-4 text-center reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="text-[0.65rem] font-bold text-brand-blue tracking-wider uppercase block mb-2">{s.category}</span>
            <p class="text-sm font-medium text-brand-dark">{s.coaches}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Events organized -->
  <section class="py-16 md:py-24 px-5">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-display text-3xl font-bold text-brand-dark text-center mb-12 reveal">Gare Organizzate</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white border-2 border-brand-dark shadow-[5px_5px_0_#1A1A1A] p-6 reveal reveal-delay-1">
          <span class="text-3xl block mb-3">🏆</span>
          <h3 class="font-display text-xl font-bold text-brand-dark mb-2">Trofeo Merelli Fiorenza</h3>
          <p class="text-xs font-bold text-brand-blue tracking-wider uppercase mb-3">43 edizioni — Lizzola, pista "Due Baite"</p>
          <p class="text-sm text-brand-dark/60 leading-relaxed">
            Slalom Speciale per la categoria Children del Circuito Provinciale FISI Bergamo.
            Intitolato alla memoria di Fiorenza Merelli, e una delle gare piu longeve della provincia.
          </p>
        </div>
        <div class="bg-white border-2 border-brand-dark shadow-[5px_5px_0_#1A1A1A] p-6 reveal reveal-delay-2">
          <span class="text-3xl block mb-3">⛷️</span>
          <h3 class="font-display text-xl font-bold text-brand-dark mb-2">Trofeo La Penzana del Merel</h3>
          <p class="text-xs font-bold text-brand-blue tracking-wider uppercase mb-3">Lizzola — Circuito Provinciale Pulcini</p>
          <p class="text-sm text-brand-dark/60 leading-relaxed">
            Slalom Speciale per le categorie Baby, Cuccioli e Pulcini. Il nome richiama la storica pizzeria
            di Tarcisio Merelli dove il club e stato fondato nel 1968.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Legends — 2022 reunion -->
  <section class="py-12 md:py-16 px-5 bg-brand-ice">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="font-display text-2xl font-bold text-brand-dark mb-2 reveal">Le Vecchie Glorie</h2>
      <p class="text-brand-dark/50 text-sm mb-6 reveal reveal-delay-1">Dalla festa delle Vecchie Glorie 2022 — omaggio a Giuseppe Panizza</p>
      <div class="flex flex-wrap justify-center gap-2 reveal reveal-delay-2">
        {LEGENDS.map(name => (
          <span class="inline-block bg-white border border-brand-dark/10 px-3 py-1.5 text-sm font-medium text-brand-dark hover:border-brand-blue/30 transition-colors">
            {name}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 px-5 bg-brand-snow">
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-brand-dark/60 text-sm mb-4">Segui i nostri risultati su Instagram</p>
      <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-7 py-3 bg-brand-dark text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-dark hover:bg-brand-blue hover:border-brand-blue transition-all">
        @scicluborezzo
      </a>
    </div>
  </section>

  <div class="text-center py-12">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-brand-blue hover:underline">
      &larr; Torna alla home
    </a>
  </div>

</BaseLayout>
