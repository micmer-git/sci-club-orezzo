---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.js';

const WORKER_URL = 'https://scicluborezzo-forms.micmer-recastello.workers.dev';
---

<BaseLayout
  title="Contatti — Sci Club Orezzo"
  description="Contatta lo Sci Club Orezzo. Informazioni su iscrizioni, corsi di sci e attivita agonistica. Invia i tuoi risultati gara."
>

  <!-- Hero -->
  <section class="relative py-28 md:py-36 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-dark via-brand-dark/90 to-brand-blue/20"></div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-blue text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Scrivici</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,4.5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        Contatti
      </h1>
      <p class="text-white/60 text-lg max-w-xl mx-auto reveal reveal-delay-2">
        Per informazioni su iscrizioni, corsi, attivita agonistica e collaborazioni.
      </p>
    </div>
  </section>

  <!-- Tab switcher -->
  <div class="max-w-5xl mx-auto px-5 pt-12">
    <div class="flex gap-2 justify-center mb-8">
      <button id="tab-contatto" type="button"
        class="tab-btn active px-6 py-3 text-sm font-bold tracking-wider uppercase border-2 border-brand-blue bg-brand-blue text-white transition-all">
        Contattaci
      </button>
      <button id="tab-risultato" type="button"
        class="tab-btn px-6 py-3 text-sm font-bold tracking-wider uppercase border-2 border-brand-dark/20 bg-white text-brand-dark hover:border-brand-blue hover:text-brand-blue transition-all">
        Invia Risultato Gara
      </button>
    </div>
  </div>

  <div class="max-w-5xl mx-auto px-5 pb-16 md:pb-24">
    <div class="grid lg:grid-cols-3 gap-12 lg:gap-16">

      <!-- Forms column (2/3) -->
      <div class="lg:col-span-2">

        <!-- Contact Form -->
        <div id="panel-contatto">
          <h2 class="font-display text-2xl font-bold text-brand-dark mb-2 reveal">Scrivici un Messaggio</h2>
          <p class="text-brand-dark/60 text-sm mb-8 reveal reveal-delay-1">Per iscrizioni, informazioni sui corsi e sull'attivita agonistica.</p>

          <form id="contactForm" class="space-y-5">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="c-name" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Nome</label>
                <input type="text" id="c-name" name="nome" required
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Mario" />
              </div>
              <div>
                <label for="c-surname" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Cognome</label>
                <input type="text" id="c-surname" name="cognome" required
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Rossi" />
              </div>
            </div>

            <div>
              <label for="c-email" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Email</label>
              <input type="email" id="c-email" name="email" required
                class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                placeholder="mario@email.com" />
            </div>

            <div>
              <label for="c-subject" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Oggetto</label>
              <select id="c-subject" name="oggetto"
                class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark focus:border-brand-blue focus:outline-none transition-colors">
                <option value="info">Informazioni generali</option>
                <option value="iscrizione">Iscrizione al club</option>
                <option value="corsi">Corsi di sci</option>
                <option value="sponsor">Sponsorizzazione / Partnership</option>
                <option value="altro">Altro</option>
              </select>
            </div>

            <div>
              <label for="c-msg" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Messaggio</label>
              <textarea id="c-msg" name="messaggio" rows="5" required
                class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors resize-y"
                placeholder="Scrivi il tuo messaggio..."></textarea>
            </div>

            <button type="submit" id="btn-contatto"
              class="w-full px-7 py-3.5 bg-brand-blue text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-blue hover:bg-brand-dark hover:border-brand-dark transition-all">
              Invia messaggio
            </button>
          </form>

          <div id="success-contatto" class="hidden bg-brand-blue/10 border-2 border-brand-blue p-8 text-center">
            <p class="font-display text-2xl font-bold text-brand-blue mb-2">Messaggio inviato!</p>
            <p class="text-brand-dark/60">Ti risponderemo il prima possibile. Grazie!</p>
          </div>
        </div>

        <!-- Result Submission Form -->
        <div id="panel-risultato" class="hidden">
          <h2 class="font-display text-2xl font-bold text-brand-dark mb-2 reveal">Invia il tuo Risultato</h2>
          <p class="text-brand-dark/60 text-sm mb-8 reveal reveal-delay-1">Condividi il risultato della tua gara con il club. Le foto migliori verranno pubblicate sul sito!</p>

          <form id="resultForm" class="space-y-5">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="r-name" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Nome</label>
                <input type="text" id="r-name" name="nome" required
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Mario" />
              </div>
              <div>
                <label for="r-surname" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Cognome</label>
                <input type="text" id="r-surname" name="cognome" required
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Rossi" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="r-gara" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Gara</label>
                <input type="text" id="r-gara" name="gara" required
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Trofeo Topolino" />
              </div>
              <div>
                <label for="r-luogo" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Luogo</label>
                <input type="text" id="r-luogo" name="luogo"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="Foppolo (BG)" />
              </div>
            </div>

            <div class="grid grid-cols-3 gap-4">
              <div>
                <label for="r-data" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Data</label>
                <input type="date" id="r-data" name="data"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark focus:border-brand-blue focus:outline-none transition-colors" />
              </div>
              <div>
                <label for="r-posizione" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Posizione</label>
                <input type="text" id="r-posizione" name="posizione"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="3" />
              </div>
              <div>
                <label for="r-tempo" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Tempo</label>
                <input type="text" id="r-tempo" name="tempo"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="1:23.45" />
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label for="r-specialita" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Specialita</label>
                <select id="r-specialita" name="specialita"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark focus:border-brand-blue focus:outline-none transition-colors">
                  <option value="">Seleziona...</option>
                  <option value="SL">Slalom (SL)</option>
                  <option value="GS">Slalom Gigante (GS)</option>
                  <option value="SG">Super-G (SG)</option>
                  <option value="DH">Discesa Libera (DH)</option>
                  <option value="Fondo">Sci di Fondo</option>
                  <option value="Alpinismo">Sci Alpinismo</option>
                </select>
              </div>
              <div>
                <label for="r-instagram" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Instagram</label>
                <input type="text" id="r-instagram" name="instagram"
                  class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors"
                  placeholder="@tuohandle" />
              </div>
            </div>

            <div>
              <label for="r-racconto" class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Racconto della gara</label>
              <textarea id="r-racconto" name="racconto" rows="4"
                class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark placeholder:text-brand-dark/30 focus:border-brand-blue focus:outline-none transition-colors resize-y"
                placeholder="Com'e andata? Racconta la tua gara..."></textarea>
            </div>

            <div>
              <label class="block text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-1.5">Foto (max 3)</label>
              <input type="file" id="r-photos" accept="image/*" multiple
                class="w-full px-4 py-3 border-2 border-brand-dark/20 bg-white text-sm text-brand-dark file:mr-4 file:py-1 file:px-3 file:border-0 file:text-xs file:font-bold file:bg-brand-blue file:text-white file:uppercase file:tracking-wider file:cursor-pointer focus:border-brand-blue focus:outline-none transition-colors" />
              <p class="text-xs text-brand-dark/40 mt-1">JPG o PNG, max 3 immagini</p>
            </div>

            <button type="submit" id="btn-risultato"
              class="w-full px-7 py-3.5 bg-brand-blue text-white font-bold text-sm tracking-wider uppercase border-2 border-brand-blue hover:bg-brand-dark hover:border-brand-dark transition-all">
              Invia risultato
            </button>
          </form>

          <div id="success-risultato" class="hidden bg-brand-blue/10 border-2 border-brand-blue p-8 text-center">
            <p class="font-display text-2xl font-bold text-brand-blue mb-2">Risultato inviato!</p>
            <p class="text-brand-dark/60">Grazie per aver condiviso il tuo risultato. Lo pubblicheremo presto!</p>
          </div>
        </div>

      </div>

      <!-- Info sidebar (1/3) -->
      <div>
        <h2 class="font-display text-2xl font-bold text-brand-dark mb-8 reveal">Dove Trovarci</h2>

        <div class="space-y-4">
          <div class="bg-brand-snow p-5 border-2 border-brand-dark/10 reveal reveal-delay-1">
            <span class="block text-[0.65rem] font-bold tracking-wider uppercase text-brand-blue mb-1">Sede</span>
            <p class="text-sm font-medium text-brand-dark">{SITE.contacts.address}</p>
          </div>

          <div class="bg-brand-snow p-5 border-2 border-brand-dark/10 reveal reveal-delay-2">
            <span class="block text-[0.65rem] font-bold tracking-wider uppercase text-brand-blue mb-1">Telefono</span>
            <a href={`tel:${SITE.contacts.phone.replace(/\s/g, '')}`} class="text-sm font-medium text-brand-dark hover:text-brand-blue transition-colors">
              {SITE.contacts.phone}
            </a>
          </div>

          <div class="bg-brand-snow p-5 border-2 border-brand-dark/10 reveal reveal-delay-3">
            <span class="block text-[0.65rem] font-bold tracking-wider uppercase text-brand-blue mb-1">P.IVA</span>
            <p class="text-sm text-brand-dark">{SITE.contacts.piva}</p>
          </div>

          <div class="bg-brand-snow p-5 border-2 border-brand-dark/10 reveal reveal-delay-4">
            <span class="block text-[0.65rem] font-bold tracking-wider uppercase text-brand-blue mb-1">Affiliazione</span>
            <p class="text-sm text-brand-dark">FISI — Federazione Italiana Sport Invernali</p>
            <p class="text-xs text-brand-dark/50 mt-1">Comitato Regionale Lombardia — FISI Bergamo</p>
          </div>
        </div>

        <!-- Social -->
        <div class="mt-8 reveal reveal-delay-4">
          <h3 class="text-xs font-bold tracking-wider uppercase text-brand-dark/60 mb-4">Seguici</h3>
          <div class="flex gap-3">
            <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 bg-brand-dark text-white text-xs font-bold tracking-wider uppercase hover:bg-brand-blue transition-colors">
              Facebook
            </a>
            <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer"
              class="flex items-center gap-2 px-4 py-2 bg-brand-dark text-white text-xs font-bold tracking-wider uppercase hover:bg-brand-blue transition-colors">
              Instagram
            </a>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- Back link -->
  <div class="text-center pb-16">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-brand-blue hover:underline">
      &larr; Torna alla home
    </a>
  </div>

  <script define:vars={{ WORKER_URL }}>
    // Tab switching
    const tabContatto = document.getElementById('tab-contatto');
    const tabRisultato = document.getElementById('tab-risultato');
    const panelContatto = document.getElementById('panel-contatto');
    const panelRisultato = document.getElementById('panel-risultato');

    function switchTab(active) {
      const isContatto = active === 'contatto';
      panelContatto.classList.toggle('hidden', !isContatto);
      panelRisultato.classList.toggle('hidden', isContatto);

      tabContatto.classList.toggle('bg-brand-blue', isContatto);
      tabContatto.classList.toggle('text-white', isContatto);
      tabContatto.classList.toggle('border-brand-blue', isContatto);
      tabContatto.classList.toggle('bg-white', !isContatto);
      tabContatto.classList.toggle('text-brand-dark', !isContatto);
      tabContatto.classList.toggle('border-brand-dark/20', !isContatto);

      tabRisultato.classList.toggle('bg-brand-blue', !isContatto);
      tabRisultato.classList.toggle('text-white', !isContatto);
      tabRisultato.classList.toggle('border-brand-blue', !isContatto);
      tabRisultato.classList.toggle('bg-white', isContatto);
      tabRisultato.classList.toggle('text-brand-dark', isContatto);
      tabRisultato.classList.toggle('border-brand-dark/20', isContatto);
    }

    tabContatto.addEventListener('click', () => switchTab('contatto'));
    tabRisultato.addEventListener('click', () => switchTab('risultato'));

    // File to base64
    function fileToBase64(file) {
      return new Promise((resolve, reject) => {
        const reader = new FileReader();
        reader.onload = () => resolve(reader.result);
        reader.onerror = reject;
        reader.readAsDataURL(file);
      });
    }

    // Send email via FormSubmit.co (browser-side, always works)
    async function sendEmail(formData, type) {
      const emailPayload = {
        _subject: type === 'contatto'
          ? `Sci Club Orezzo — Contatto: ${formData.nome} ${formData.cognome}`
          : `Sci Club Orezzo — Risultato: ${formData.nome} ${formData.cognome} — ${formData.gara || ''}`,
        _replyto: formData.email || '',
        _captcha: 'false',
        _template: 'table',
      };
      // Copy all fields except internal ones
      for (const [k, v] of Object.entries(formData)) {
        if (k !== '_type' && k !== 'photos' && v) emailPayload[k] = v;
      }
      try {
        await fetch('https://formsubmit.co/ajax/info@scicluborezzo.com', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(emailPayload),
        });
      } catch (e) { /* best effort */ }
    }

    // Submit handler
    async function submitForm(form, type, btnId, successId) {
      const btn = document.getElementById(btnId);
      const successEl = document.getElementById(successId);
      const originalText = btn.textContent;

      btn.disabled = true;
      btn.textContent = 'Invio in corso...';
      btn.classList.add('opacity-60');

      try {
        const formData = new FormData(form);
        const payload = { _type: type };

        for (const [key, value] of formData.entries()) {
          if (key !== 'photos') payload[key] = value;
        }

        // Handle photos for risultato
        if (type === 'risultato') {
          const photoInput = document.getElementById('r-photos');
          if (photoInput.files.length > 0) {
            const photos = [];
            const files = Array.from(photoInput.files).slice(0, 3);
            for (const file of files) {
              photos.push(await fileToBase64(file));
            }
            payload.photos = photos;
          }
        }

        // Send to Worker (GitHub Issues) + Email in parallel
        const [workerRes] = await Promise.all([
          fetch(WORKER_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          }),
          sendEmail(payload, type),
        ]);

        const data = await workerRes.json();

        if (data.ok) {
          form.classList.add('hidden');
          successEl.classList.remove('hidden');
        } else {
          throw new Error(data.error || 'Errore sconosciuto');
        }
      } catch (err) {
        alert('Errore nell\'invio: ' + err.message);
        btn.disabled = false;
        btn.textContent = originalText;
        btn.classList.remove('opacity-60');
      }
    }

    document.getElementById('contactForm').addEventListener('submit', (e) => {
      e.preventDefault();
      submitForm(e.target, 'contatto', 'btn-contatto', 'success-contatto');
    });

    document.getElementById('resultForm').addEventListener('submit', (e) => {
      e.preventDefault();
      submitForm(e.target, 'risultato', 'btn-risultato', 'success-risultato');
    });
  </script>

</BaseLayout>
