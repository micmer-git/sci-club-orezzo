---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, SPONSORS, SPONSOR_PACKAGES } from '../data/site.js';

const tierColors = {
  Gold: { bg: 'from-amber-400 to-amber-600', border: 'border-amber-500', text: 'text-amber-600', badge: 'bg-amber-100 text-amber-700', shadow: 'shadow-[6px_6px_0_#d97706]', check: 'text-amber-500' },
  Silver: { bg: 'from-gray-300 to-gray-500', border: 'border-gray-400', text: 'text-gray-600', badge: 'bg-gray-100 text-gray-700', shadow: 'shadow-[5px_5px_0_#6b7280]', check: 'text-gray-500' },
  Bronze: { bg: 'from-orange-400 to-orange-700', border: 'border-orange-500', text: 'text-orange-600', badge: 'bg-orange-100 text-orange-700', shadow: 'shadow-[4px_4px_0_#c2410c]', check: 'text-orange-500' },
};

const stats = [
  { num: '57', label: 'Atleti agonisti' },
  { num: '118', label: 'Tesserati FISI' },
  { num: '1000+', label: 'Atleti formati in 55 anni' },
  { num: '275', label: 'Post Instagram' },
];
---

<BaseLayout
  title="Diventa Sponsor — Sci Club Orezzo"
  description="Sponsorizza lo Sci Club Orezzo. Pacchetti Gold, Silver e Bronze per aziende che vogliono associare il proprio brand allo sci alpino bergamasco."
>

  <!-- Hero -->
  <section class="relative py-28 md:py-40 px-5 bg-brand-dark text-white overflow-hidden">
    <div class="absolute inset-0">
      <img src="/img/montagna-sfondo.jpg" alt="" class="w-full h-full object-cover opacity-20" />
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/70 via-brand-dark/50 to-brand-blue/30"></div>
    </div>
    <div class="absolute bottom-0 left-0 right-0 z-10">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none" class="w-full h-20 md:h-28" aria-hidden="true">
        <path d="M0,120 L0,80 L80,50 L160,70 L280,20 L400,60 L520,10 L640,55 L760,25 L880,65 L1000,15 L1120,50 L1240,30 L1360,55 L1440,40 L1440,120 Z" fill="#F0F4F8"/>
      </svg>
    </div>
    <div class="relative z-10 max-w-4xl mx-auto text-center">
      <p class="text-brand-blue text-xs font-bold tracking-[0.25em] uppercase mb-4 reveal">Partnership</p>
      <h1 class="font-display text-[clamp(2.5rem,8vw,4.5rem)] font-bold leading-tight mb-6 reveal reveal-delay-1">
        Diventa Sponsor
      </h1>
      <p class="text-white/60 text-lg max-w-2xl mx-auto reveal reveal-delay-2">
        Associa il tuo brand a una delle societa di sci alpino piu storiche della provincia di Bergamo. Dal 1968 sulle montagne delle Orobie.
      </p>
    </div>
  </section>

  <!-- Perche sponsorizzare -->
  <section class="py-20 md:py-28 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">I numeri</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          Perche Sponsorizzare lo Sci Club Orezzo
        </h2>
        <p class="text-brand-dark/60 max-w-2xl mx-auto reveal reveal-delay-2">
          Oltre mezzo secolo di attivita, migliaia di famiglie coinvolte, gare FISI provinciali e regionali, e una presenza social in costante crescita.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto mb-16">
        {stats.map((stat, i) => (
          <div class={`text-center glass-card-light p-6 rounded-lg reveal-scale reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="font-display text-3xl md:text-4xl font-bold text-brand-blue block">{stat.num}</span>
            <span class="text-xs text-brand-dark/50 font-bold tracking-wider uppercase mt-2 block">{stat.label}</span>
          </div>
        ))}
      </div>

      <!-- Benefits overview -->
      <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto">
        {[
          { icon: '🏔️', title: 'Visibilita alle gare', desc: 'Banner e striscioni alle gare FISI provinciali e regionali, con centinaia di famiglie presenti ad ogni evento.' },
          { icon: '📱', title: 'Presenza digitale', desc: 'Logo sul sito web, menzioni su Instagram (1.059 follower, 275 post) e comunicazioni ufficiali del club.' },
          { icon: '🏆', title: 'Brand association', desc: 'Associa il tuo marchio ai valori dello sport giovanile, della tradizione alpina e del territorio bergamasco.' },
        ].map((b, i) => (
          <div class={`bg-white border-2 border-brand-dark shadow-[5px_5px_0_#1A1A1A] hover:translate-x-[3px] hover:translate-y-[3px] hover:shadow-[2px_2px_0_#1A1A1A] transition-all p-8 text-center reveal reveal-delay-${Math.min(i + 1, 4)}`}>
            <span class="text-4xl block mb-4">{b.icon}</span>
            <h3 class="font-display text-lg font-bold text-brand-dark mb-3">{b.title}</h3>
            <p class="text-sm text-brand-dark/60 leading-relaxed">{b.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mountain divider -->
  <div class="mountain-divider bg-brand-snow">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,60 L0,30 Q120,60 240,25 Q360,0 480,35 Q600,55 720,20 Q840,0 960,30 Q1080,50 1200,15 Q1320,0 1440,25 L1440,60 Z" fill="#F0F4F8"/>
    </svg>
  </div>

  <!-- Sponsor packages -->
  <section class="py-20 md:py-28 px-5 bg-brand-snow">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Pacchetti</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          Scegli il Tuo Pacchetto
        </h2>
        <p class="text-brand-dark/60 max-w-xl mx-auto reveal reveal-delay-2">
          Tre livelli di sponsorizzazione per ogni esigenza e budget.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {SPONSOR_PACKAGES.map((pkg, i) => {
          const colors = tierColors[pkg.tier];
          return (
            <div class={`bg-white border-2 ${colors.border} ${colors.shadow} p-8 reveal reveal-delay-${Math.min(i + 1, 4)} ${pkg.tier === 'Gold' ? 'md:-translate-y-4' : ''}`}>
              <div class="text-center mb-6">
                <span class={`inline-block px-3 py-1 ${colors.badge} text-[0.65rem] font-bold tracking-[0.15em] uppercase mb-3`}>
                  {pkg.tier}
                </span>
                <h3 class="font-display text-2xl font-bold text-brand-dark">{pkg.tier}</h3>
                <p class={`${colors.text} text-sm font-bold mt-1`}>{pkg.price}</p>
              </div>
              <ul class="space-y-3 mb-8">
                {pkg.benefits.map(benefit => (
                  <li class="flex items-start gap-3">
                    <svg class={`w-5 h-5 ${colors.check} flex-shrink-0 mt-0.5`} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span class="text-sm text-brand-dark/70">{benefit}</span>
                  </li>
                ))}
              </ul>
              <a
                href="https://wa.me/393491019679?text=Ciao%2C%20vorrei%20informazioni%20sulla%20sponsorizzazione%20dello%20Sci%20Club%20Orezzo"
                target="_blank"
                rel="noopener noreferrer"
                class={`block w-full text-center px-6 py-3 font-bold text-sm tracking-wider uppercase border-2 transition-all ${pkg.tier === 'Gold' ? 'bg-brand-blue text-white border-brand-blue hover:bg-brand-dark hover:border-brand-dark' : 'bg-white text-brand-dark border-brand-dark/20 hover:border-brand-blue hover:text-brand-blue'}`}
              >
                Richiedi info
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Mountain divider -->
  <div class="mountain-divider">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,60 L0,25 Q150,50 300,20 Q450,0 600,35 Q750,55 900,15 Q1050,0 1200,30 Q1350,50 1440,20 L1440,60 Z" fill="#F0F4F8"/>
    </svg>
  </div>

  <!-- Current sponsors -->
  <section class="py-20 md:py-28 px-5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-brand-blue text-xs font-bold tracking-[0.2em] uppercase mb-3 reveal">Chi ci sostiene</p>
        <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold text-brand-dark leading-tight mb-4 reveal reveal-delay-1">
          I Nostri Partner
        </h2>
        <p class="text-brand-dark/60 max-w-xl mx-auto reveal reveal-delay-2">
          Aziende del territorio bergamasco che credono nello sport giovanile e nella tradizione alpina.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
        {SPONSORS.map((sponsor, i) => (
          <a
            href={sponsor.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`glass-card-light p-5 rounded-lg text-center no-underline hover:scale-[1.03] transition-all reveal reveal-delay-${Math.min(i + 1, 4)}`}
          >
            <div class="h-20 flex items-center justify-center mb-3">
              <img src={sponsor.logo} alt={`Logo ${sponsor.name}`} class="max-h-full max-w-full object-contain" loading="lazy" />
            </div>
            <h3 class="font-display text-sm font-bold text-brand-dark">{sponsor.name}</h3>
            <span class={`inline-block mt-1 text-[0.55rem] font-bold tracking-[0.15em] uppercase ${sponsor.tier === 'main' ? 'text-brand-blue' : sponsor.tier === 'storico' ? 'text-purple-600' : sponsor.tier === 'technical' ? 'text-amber-600' : 'text-brand-dark/40'}`}>
              {sponsor.tier === 'main' ? 'Main Sponsor' : sponsor.tier === 'technical' ? 'Partner Tecnico' : sponsor.tier === 'storico' ? 'Sponsor Storico' : 'Supporter'}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Mountain divider -->
  <div class="mountain-divider">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,60 L0,30 Q180,55 360,20 Q540,0 720,40 Q900,55 1080,15 Q1260,0 1440,35 L1440,60 Z" fill="#1A1A1A"/>
    </svg>
  </div>

  <!-- CTA -->
  <section class="py-20 md:py-28 px-5 bg-brand-dark text-white relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <img src="/img/neve-sfondo.jpg" alt="" class="w-full h-full object-cover" />
    </div>
    <div class="relative z-10 max-w-3xl mx-auto text-center">
      <h2 class="font-display text-[clamp(2rem,5vw,3rem)] font-bold leading-tight mb-6 reveal">
        Contattaci per un Preventivo Personalizzato
      </h2>
      <p class="text-white/60 text-lg mb-10 reveal reveal-delay-1">
        Ogni partnership e unica. Parliamo delle tue esigenze e creiamo insieme il pacchetto ideale per la tua azienda.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-2">
        <a
          href="https://wa.me/393491019679?text=Ciao%2C%20vorrei%20informazioni%20sulla%20sponsorizzazione%20dello%20Sci%20Club%20Orezzo"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-shine inline-flex items-center gap-3 px-7 py-3 bg-[#25D366] text-white font-bold text-sm tracking-wider uppercase border-2 border-[#25D366] hover:bg-transparent hover:text-[#25D366] transition-all"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Scrivici su WhatsApp
        </a>
        <a href="/contatti/" class="btn-shine inline-flex items-center gap-2 px-7 py-3 bg-transparent text-white font-bold text-sm tracking-wider uppercase border-2 border-white/40 hover:border-white hover:bg-white/10 transition-all">
          Contattaci via form
        </a>
      </div>
    </div>
  </section>

  <!-- Back link -->
  <div class="bg-brand-dark text-center pb-16">
    <a href="/" class="inline-flex items-center gap-2 text-sm font-bold text-brand-blue hover:underline">
      &larr; Torna alla home
    </a>
  </div>

</BaseLayout>
